{% extends "layouts/base.twig" %}
{% block title %}Results — {{ survey.title }}{% endblock %}
{% block content %}

<div class="flex items-start justify-between mb-8">
    <div>
        <a href="/admin/dashboard" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">← Dashboard</a>
        <h1 class="text-2xl font-semibold text-zinc-900 mt-3">{{ survey.title }}</h1>
        <p class="text-sm text-zinc-500 mt-1">
            {{ participants|length }} participant{{ participants|length != 1 ? 's' : '' }} ·
            {{ questions|length }} question{{ questions|length != 1 ? 's' : '' }} ·
            {% if survey.is_active %}<span class="text-emerald-600">Active</span>{% else %}<span class="text-zinc-400">Inactive</span>{% endif %}
        </p>
    </div>
    <div class="flex gap-3">
        <button onclick="navigator.clipboard.writeText('{{ survey.getSurveyUrl() }}').then(()=>this.textContent='Copied!')"
                class="text-xs font-mono text-zinc-600 border border-zinc-200 rounded-lg px-3 py-2 hover:border-zinc-400 transition-all">
            Copy URL
        </button>
        {% if participants|length > 0 %}
        <a href="/admin/results/{{ survey.id }}/download"
           class="inline-flex items-center gap-2 bg-zinc-900 text-white text-sm font-medium px-4 py-2.5 rounded-xl hover:bg-zinc-800 transition-all">
            ↓ Download CSV
        </a>
        {% endif %}
    </div>
</div>

{% if participants is empty %}
    <div class="bg-white border-2 border-dashed border-zinc-200 rounded-2xl p-20 text-center">
        <div class="text-4xl mb-3">⏳</div>
        <p class="font-medium text-zinc-700">No responses yet</p>
        {% if survey.is_active %}
            <p class="text-sm text-zinc-400 mt-2 mb-3">Share this link with participants:</p>
            <code class="text-xs text-indigo-700 bg-indigo-50 border border-indigo-100 px-4 py-2 rounded-lg inline-block font-mono">
                {{ survey.getSurveyUrl() }}
            </code>
        {% else %}
            <p class="text-sm text-zinc-400 mt-2">Activate this survey to allow responses.</p>
        {% endif %}
    </div>
{% else %}

    {# Summary stats #}
    {% set avg = 0 %}{% set high = 0 %}{% set low = 100 %}{% set pass = 0 %}
    {% for p in participants %}
        {% set avg  = avg + p.percentage %}
        {% if p.percentage > high %}{% set high = p.percentage %}{% endif %}
        {% if p.percentage < low  %}{% set low  = p.percentage %}{% endif %}
        {% if p.percentage >= 70  %}{% set pass = pass + 1 %}{% endif %}
    {% endfor %}
    {% set avg = (avg / participants|length)|round %}

    <div class="grid grid-cols-4 gap-4 mb-6">
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Average score</p>
            <p class="text-2xl font-semibold text-zinc-900">{{ avg }}%</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Highest score</p>
            <p class="text-2xl font-semibold text-emerald-600">{{ high }}%</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Lowest score</p>
            <p class="text-2xl font-semibold text-red-500">{{ low }}%</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Passed (≥70%)</p>
            <p class="text-2xl font-semibold text-zinc-900">{{ pass }}</p>
        </div>
    </div>

    {# Results table #}
    <div class="bg-white border border-zinc-200 rounded-2xl shadow-sm overflow-x-auto mb-6">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-zinc-100 bg-zinc-50">
                    <th class="text-left text-xs font-medium text-zinc-400 uppercase tracking-wider px-5 py-3">#</th>
                    <th class="text-left text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3">Submitted</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3">Score</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3">%</th>
                    {% for q in questions %}
                        <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-3 py-3" title="{{ q.question_text }}">Q{{ q.order }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-50">
                {% for i, p in participants %}
                <tr class="hover:bg-zinc-50 transition-colors">
                    <td class="px-5 py-3.5 text-zinc-400 text-xs">{{ i + 1 }}</td>
                    <td class="px-4 py-3.5 text-zinc-500 text-xs font-mono whitespace-nowrap">{{ p.submitted_at }}</td>
                    <td class="px-4 py-3.5 text-center font-medium text-zinc-800">{{ p.score }}/{{ p.total }}</td>
                    <td class="px-4 py-3.5 text-center">
                        <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full
                            {% if p.percentage >= 70 %}bg-emerald-50 text-emerald-700
                            {% elseif p.percentage >= 40 %}bg-amber-50 text-amber-700
                            {% else %}bg-red-50 text-red-600{% endif %}">
                            {{ p.percentage }}%
                        </span>
                    </td>
                    {% for q in questions %}
                        {% set resp = p.answers[q.id] ?? null %}
                        <td class="px-3 py-3.5 text-center text-sm" title="{{ resp ? resp.selected_answer : 'No answer' }}">
                            {% if resp %}{{ resp.is_correct ? '✅' : '❌' }}{% else %}<span class="text-zinc-200">—</span>{% endif %}
                        </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Question key #}
    <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
        <h2 class="text-sm font-semibold text-zinc-700 mb-5">Question Key</h2>
        <div class="space-y-4">
            {% for q in questions %}
            <div class="flex gap-4">
                <span class="text-xs font-mono text-zinc-400 w-6 shrink-0 pt-0.5">Q{{ q.order }}</span>
                <div>
                    <p class="text-sm text-zinc-800">{{ q.question_text }}</p>
                    <p class="text-xs text-emerald-600 mt-1">✓ {{ q.correct_answer }}</p>
                    <p class="text-xs text-zinc-400 mt-0.5">Wrong: {{ q.wrong_options|join(', ') }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

{% endif %}
{% endblock %}
