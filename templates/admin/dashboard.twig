{% extends "layouts/base.twig" %}
{% block title %}Dashboard{% endblock %}
{% block content %}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-semibold text-zinc-900">Surveys</h1>
        <p class="text-sm text-zinc-500 mt-1">{{ surveys|length }} questionnaire{{ surveys|length != 1 ? 's' : '' }} total</p>
    </div>
    <a href="/admin/upload"
       class="inline-flex items-center gap-2 bg-zinc-900 text-white text-sm font-medium px-4 py-2.5 rounded-xl hover:bg-zinc-800 active:scale-[0.98] transition-all">
        + Upload CSV
    </a>
</div>

{% if surveys is empty %}
    <div class="bg-white border-2 border-dashed border-zinc-200 rounded-2xl p-20 text-center">
        <div class="text-5xl mb-4">📋</div>
        <p class="font-medium text-zinc-700">No surveys yet</p>
        <p class="text-sm text-zinc-400 mt-1 mb-5">Upload a CSV file to create your first questionnaire.</p>
        <a href="/admin/upload" class="inline-flex text-sm font-medium text-zinc-900 border border-zinc-900 rounded-lg px-4 py-2 hover:bg-zinc-900 hover:text-white transition-all">
            Upload your first CSV →
        </a>
    </div>
{% else %}

    {# Stats row #}
    {% set active_count = 0 %}
    {% set total_responses = 0 %}
    {% for s in surveys %}
        {% if s.is_active %}{% set active_count = active_count + 1 %}{% endif %}
        {% set total_responses = total_responses + s.respondent_count %}
    {% endfor %}

    <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Active surveys</p>
            <p class="text-2xl font-semibold text-zinc-900">{{ active_count }}</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Inactive surveys</p>
            <p class="text-2xl font-semibold text-zinc-900">{{ surveys|length - active_count }}</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-4">
            <p class="text-xs text-zinc-400 mb-1">Total participants</p>
            <p class="text-2xl font-semibold text-zinc-900">{{ total_responses }}</p>
        </div>
    </div>

    {# Surveys table #}
    <div class="bg-white border border-zinc-200 rounded-2xl overflow-hidden shadow-sm">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-zinc-100 bg-zinc-50">
                    <th class="text-left text-xs font-medium text-zinc-400 uppercase tracking-wider px-6 py-3.5">Title</th>
                    <th class="text-left text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3.5">Survey URL</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3.5">Status</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3.5">Questions</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3.5">Responses</th>
                    <th class="text-center text-xs font-medium text-zinc-400 uppercase tracking-wider px-4 py-3.5">Created</th>
                    <th class="text-right text-xs font-medium text-zinc-400 uppercase tracking-wider px-6 py-3.5">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-50">
                {% for survey in surveys %}
                <tr class="hover:bg-zinc-50 transition-colors">
                    <td class="px-6 py-4 font-medium text-zinc-900">{{ survey.title }}</td>
                    <td class="px-4 py-4">
                        {% if survey.is_active %}
                            <a href="{{ survey.survey_url }}" target="_blank"
                               class="font-mono text-xs text-indigo-600 hover:underline">
                                /survey/{{ survey.token|slice(0, 8) }}…
                            </a>
                        {% else %}
                            <span class="font-mono text-xs text-zinc-400">/survey/{{ survey.token|slice(0, 8) }}… (off)</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-4 text-center">
                        {% if survey.is_active %}
                            <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 text-xs font-medium px-2.5 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span> Active
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 bg-zinc-100 text-zinc-500 border border-zinc-200 text-xs font-medium px-2.5 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-zinc-400 inline-block"></span> Inactive
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-4 text-center text-zinc-600">{{ survey.question_count }}</td>
                    <td class="px-4 py-4 text-center text-zinc-600">{{ survey.respondent_count }}</td>
                    <td class="px-4 py-4 text-center text-zinc-400 text-xs">{{ survey.created_at|date("M d, Y") }}</td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-2">
                            <a href="/admin/results/{{ survey.id }}"
                               class="text-xs text-zinc-600 border border-zinc-200 rounded-lg px-3 py-1.5 hover:border-zinc-400 transition-all">
                                Results
                            </a>
                            <form method="POST" action="/admin/toggle/{{ survey.id }}">
                                <button class="text-xs border rounded-lg px-3 py-1.5 transition-all
                                    {{ survey.is_active ? 'text-amber-700 border-amber-200 hover:bg-amber-50' : 'text-emerald-700 border-emerald-200 hover:bg-emerald-50' }}">
                                    {{ survey.is_active ? 'Deactivate' : 'Activate' }}
                                </button>
                            </form>
                            <form method="POST" action="/admin/delete/{{ survey.id }}"
                                  onsubmit="return confirm('Delete {{ survey.title }} and all its data?')">
                                <button class="text-xs text-red-500 border border-red-200 rounded-lg px-3 py-1.5 hover:bg-red-50 transition-all">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}

{% endblock %}
