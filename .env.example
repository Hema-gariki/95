APP_NAME=SurveyFlow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database — SQLite (easiest, no extra software needed)
DB_DRIVER=sqlite
DB_DATABASE=database/surveyflow.sqlite

# Database — MySQL (uncomment to use instead)
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=surveyflow
# DB_USERNAME=root
# DB_PASSWORD=secret

# Session
SESSION_NAME=surveyflow_session
SESSION_LIFETIME=7200

# Default admin account (used when seeding)
ADMIN_EMAIL=admin@surveyflow.test
ADMIN_PASSWORD=password
