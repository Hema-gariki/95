{% extends "layouts/base.twig" %}
{% block title %}Upload Survey{% endblock %}
{% block content %}

<div class="max-w-2xl mx-auto">

    <div class="mb-8">
        <a href="/admin/dashboard" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">← Dashboard</a>
        <h1 class="text-2xl font-semibold text-zinc-900 mt-3">Upload New Survey</h1>
        <p class="text-sm text-zinc-500 mt-1">Upload a CSV to instantly create a questionnaire with its own unique URL.</p>
    </div>

    <div class="bg-white rounded-2xl border border-zinc-200 shadow-sm p-8">
        <form method="POST" action="/admin/upload" enctype="multipart/form-data" class="space-y-6">

            <div>
                <label for="title" class="block text-sm font-medium text-zinc-700 mb-1.5">
                    Survey Topic Name <span class="text-red-400">*</span>
                </label>
                <input id="title" name="title" type="text" required
                       placeholder="e.g. General Knowledge Quiz — Spring 2025"
                       class="w-full border border-zinc-300 rounded-lg px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900 transition">
                <p class="text-xs text-zinc-400 mt-1.5">Must be unique. Shown to participants at the top of the quiz.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-zinc-700 mb-1.5">
                    CSV File <span class="text-red-400">*</span>
                </label>
                <label for="csv" class="relative flex flex-col items-center justify-center w-full h-36 border-2 border-dashed border-zinc-300 rounded-xl cursor-pointer hover:border-zinc-500 hover:bg-zinc-50 transition-all group">
                    <input id="csv" name="csv" type="file" accept=".csv,.txt" required
                           class="absolute inset-0 opacity-0 cursor-pointer"
                           onchange="document.getElementById('fname').textContent = this.files[0]?.name ?? 'No file chosen'">
                    <span class="text-3xl mb-2">📂</span>
                    <p class="text-sm text-zinc-600">Click to browse or drag &amp; drop</p>
                    <p id="fname" class="text-xs text-indigo-600 font-medium mt-1">No file chosen</p>
                    <p class="text-xs text-zinc-400 mt-1">.csv or .txt — max 2 MB</p>
                </label>
            </div>

            <button type="submit"
                    class="w-full bg-zinc-900 text-white rounded-xl py-3 text-sm font-medium hover:bg-zinc-800 active:scale-[0.99] transition-all">
                Upload &amp; Create Survey →
            </button>
        </form>
    </div>

    {# CSV format guide #}
    <div class="mt-6 bg-indigo-50 border border-indigo-100 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-indigo-800 mb-3">📌 CSV Format</h2>
        <p class="text-xs font-mono text-indigo-700 bg-indigo-100 rounded-lg px-3 py-2 mb-3">
            Question, CorrectAnswer, WrongOption1, WrongOption2, ...
        </p>
        <div class="bg-white rounded-xl border border-indigo-100 p-4 font-mono text-xs text-zinc-700 space-y-1 overflow-x-auto">
            <p class="text-zinc-400"># Optional header row is auto-skipped</p>
            <p>What is the capital of France?,Paris,London,Berlin,Madrid</p>
            <p>What is 2+2?,4,3,5,6</p>
            <p>Which planet is closest to the Sun?,Mercury,Venus,Earth,Mars</p>
        </div>
        <ul class="text-xs text-indigo-700 mt-4 space-y-1.5">
            <li>• Column 1 — Question text</li>
            <li>• Column 2 — The correct answer</li>
            <li>• Column 3+ — Wrong options (at least one required)</li>
            <li>• All options are shuffled randomly for each participant</li>
        </ul>
    </div>

</div>
{% endblock %}
