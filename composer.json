{
    "name": "your-org/surveyflow-slim",
    "description": "Anonymous CSV-based survey system built with Slim 4",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.8",
        "illuminate/database": "^10.0",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "setup": "php database/migrate.php --fresh --seed"
    }
}
