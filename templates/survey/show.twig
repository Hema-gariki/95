<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ survey.title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config={theme:{extend:{fontFamily:{sans:['DM Sans','sans-serif']}}}}</script>
    <style>body{font-family:'DM Sans',sans-serif;}</style>
</head>
<body class="min-h-screen bg-slate-50">

<header class="bg-white border-b border-slate-200 sticky top-0 z-10">
    <div class="max-w-2xl mx-auto px-5 h-14 flex items-center justify-between">
        <span class="text-sm font-semibold text-slate-800 truncate">{{ survey.title }}</span>
        <span class="text-xs text-slate-400 shrink-0 ml-4">{{ questions|length }} questions</span>
    </div>
</header>

<div class="max-w-2xl mx-auto px-5 py-10">

    <div class="text-center mb-10">
        <div class="w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white text-2xl mx-auto mb-4">📋</div>
        <h1 class="text-2xl font-semibold text-slate-900">{{ survey.title }}</h1>
        <p class="text-sm text-slate-500 mt-2">{{ questions|length }} multiple-choice question{{ questions|length != 1 ? 's' : '' }} · Anonymous · No login required</p>
    </div>

    <form method="POST" action="/survey/{{ survey.token }}" id="survey-form">

        <div class="space-y-6">
            {% for idx, q in questions %}
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 border-b border-slate-100 px-6 py-3 flex items-center justify-between">
                    <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wide">
                        Question {{ idx + 1 }} of {{ questions|length }}
                    </span>
                    <div class="h-1.5 bg-slate-200 rounded-full w-24 overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width:{{ ((idx + 1) / questions|length * 100)|round }}%"></div>
                    </div>
                </div>
                <div class="px-6 py-5">
                    <p class="text-base font-medium text-slate-900 leading-relaxed mb-5">{{ q.text }}</p>
                    <div class="space-y-2.5">
                        {% for option in q.options %}
                        <label class="flex items-center gap-3 cursor-pointer select-none group">
                            <input type="radio" name="answers[{{ q.id }}]" value="{{ option }}" required
                                   class="w-4 h-4 accent-indigo-600 shrink-0"
                                   onchange="highlightOption(this)">
                            <span class="option-box flex-1 text-sm text-slate-700 border border-slate-200 rounded-xl px-4 py-3 group-hover:border-indigo-300 group-hover:bg-indigo-50/50 transition-all">
                                {{ option }}
                            </span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="mt-8 text-center">
            <p class="text-xs text-slate-400 mb-4">🔒 Your answers are completely anonymous. No personal data is collected.</p>
            <button type="submit" id="submit-btn"
                    class="inline-flex items-center gap-2 bg-indigo-600 text-white font-medium px-10 py-3.5 rounded-2xl text-sm hover:bg-indigo-700 active:scale-[0.98] transition-all">
                Submit Answers →
            </button>
        </div>
    </form>
</div>

<script>
function highlightOption(radio) {
    const group = document.querySelectorAll(`input[name="${radio.name}"]`);
    group.forEach(r => {
        r.nextElementSibling.classList.remove('border-indigo-500','bg-indigo-50','text-indigo-700');
        r.nextElementSibling.classList.add('border-slate-200','text-slate-700');
    });
    radio.nextElementSibling.classList.add('border-indigo-500','bg-indigo-50','text-indigo-700');
    radio.nextElementSibling.classList.remove('border-slate-200','text-slate-700');
}
document.getElementById('survey-form').addEventListener('submit', function() {
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.textContent = 'Submitting…';
});
</script>

</body>
</html>
