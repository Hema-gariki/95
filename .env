# Copy this file to .env and fill in your values
# cp .env.example .env

APP_ENV=development
APP_DEBUG=true

# Database — MySQL
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=slim_crud
DB_USERNAME=root
DB_PASSWORD=

# To use SQLite instead (great for local dev/testing):
# DB_DRIVER=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite
